rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Keep this list in sync with src/lib/auth/allowed-emails.ts.
    function isAuthorizedCoach() {
      return request.auth != null
        && request.auth.token.email != null
        && (
          request.auth.token.email == "jaanes79@gmail.com"
          || request.auth.token.email == "trennikas@gmail.com"
        );
    }

    function isWorkspaceMetadataWrite() {
      return request.resource.data.keys().hasOnly([
          "seededAt",
          "updatedAt",
          "version",
        ])
        && request.resource.data.version == 1;
    }

    function isStateSliceWrite() {
      return request.resource.data.keys().hasOnly([
          "items",
          "updatedAt",
          "version",
        ])
        && request.resource.data.version == 1
        && "items" in request.resource.data
        && "updatedAt" in request.resource.data;
    }

    match /workspaces/{workspaceId} {
      allow get: if isAuthorizedCoach();
      allow create, update: if isAuthorizedCoach() && isWorkspaceMetadataWrite();
      allow delete: if false;

      match /state/{sliceId} {
        // The app reads the entire state subcollection with one query on refresh.
        // Query rules therefore need to allow every document in this collection,
        // not only a whitelist of specific IDs, or Firestore rejects the whole query.
        allow read: if isAuthorizedCoach();
        allow create, update: if isAuthorizedCoach() && isStateSliceWrite();
        allow delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
